{
  "name": "timetracker",
  "private": true,
  "packageManager": "pnpm@10.7.0",
  "scripts": {
    "build": "corepack pnpm -r build",
    "build:desktop": "corepack pnpm --filter @timetracker/desktop build",
    "package:desktop": "corepack pnpm --filter @timetracker/desktop package",
    "package:desktop:win": "corepack pnpm --filter @timetracker/desktop package:win",
    "make:desktop": "corepack pnpm --filter @timetracker/desktop make",
    "make:desktop:win": "corepack pnpm --filter @timetracker/desktop make:win",
    "dev:web": "corepack pnpm --filter @timetracker/web dev",
    "dev:desktop": "corepack pnpm --filter @timetracker/desktop dev",
    "dev:extension": "corepack pnpm --filter @timetracker/extension dev",
    "build:extension:firefox": "corepack pnpm --filter @timetracker/extension build:firefox",
    "start:desktop": "corepack pnpm --filter @timetracker/desktop start",
    "test": "corepack pnpm --filter @timetracker/shared test",
    "typecheck": "corepack pnpm -r typecheck"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.30",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "@types/node": "^22.13.10",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller"
    ]
  }
}
